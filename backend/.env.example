# ─── Backend environment (EventNest) ─────────────────────────────────────────
# Copy to .env and fill in. Never commit the real .env.

# Core
NODE_ENV=development
PORT=8002
MONGODB_URI=mongodb://127.0.0.1:27017/eventnest

# JWT
ACCESS_TOKEN_SECRET=change-me-access
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=change-me-refresh
REFRESH_TOKEN_EXPIRY=7d

# Frontend base (used for password-reset links; comma-separated, first is primary)
FRONTEND_URLS=http://localhost:5173

# Email (nodemailer / SMTP only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@eventnest.app
SMTP_FROM_NAME=EventNest

# File storage: "local" or "s3"
STORAGE_TYPE=local
UPLOAD_BASE_URL=http://localhost:8002/uploads
MAX_FILE_SIZE_MB=10
# S3 (only if STORAGE_TYPE=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
S3_PUBLIC_URL=

# Location lookup — required for the venue Country/State/City dropdowns.
# Get a free key at https://countrystatecity.in/ . If unset, those selects are empty.
COUNTRY_STATE_CITY_API_KEY=

# Demo seed — when CREATE_DEMO_USERS=true, demo Admin + Organizer + Attendee accounts
# are auto-created on startup (all log in with DEMO_PASS). Credentials are printed to
# the server console on boot. Set CREATE_DEMO_USERS=false to disable.
CREATE_DEMO_USERS=true
DEMO_PASS=Demo@1234
DEMO_ADMIN_EMAIL=admin@eventnest.app
DEMO_ORGANIZER_EMAIL=organizer@eventnest.app
DEMO_USER_EMAIL=user@eventnest.app
