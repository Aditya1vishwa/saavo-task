# Frontend environment (Vite) — copy to .env.local and adjust.
# All client-exposed vars MUST be prefixed with VITE_.

# Backend API base URL (include /api). Leave blank to auto-derive from window.origin.
VITE_API_BASE_URL=http://localhost:8002/api

# Base URL for uploaded media (include trailing slash). Leave blank to auto-derive.
VITE_IMG_BASE_URL=http://localhost:8002/uploads/
